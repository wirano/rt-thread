Import('RTT_ROOT')
Import('rtconfig')
from building import *
from gcc import *

cwd = GetCurrentDir()
src = []
group = []
CPPPATH = []

if rtconfig.PLATFORM in ['iccarm']:
    Return('group')
elif rtconfig.PLATFORM in GetGCCLikePLATFORM():
    src = Glob('*.c')
    CPPPATH = [cwd, ]

group = DefineGroup('rz_gen', src, depend = [''], CPPPATH = CPPPATH)
Return('group')
